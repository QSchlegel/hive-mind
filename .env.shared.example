NODE_ENV=development
APP_DOMAIN=hive-mind.club
APP_JWT_SECRET=replace-with-32-char-min-secret-1234
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
BETTER_AUTH_SECRET=replace-with-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
RESEND_API_KEY=re_xxx
RESEND_FROM=hello@hive-mind.club
TREASURY_ADMIN_EMAIL_ALLOWLIST=admin@hive-mind.club
TREASURY_ADMIN_WALLET_ALLOWLIST=0x1111111111111111111111111111111111111111
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
TREASURY_VOTE_QUORUM_XP=1000
TREASURY_DEFAULT_VOTING_WINDOW_HOURS=168
CHAIN_EVM_ENABLED=true
CHAIN_CARDANO_ENABLED=true
CHAIN_BITCOIN_ENABLED=true
BITCOIN_NETWORK=mainnet
IPFS_API_URL=http://127.0.0.1:5001/api/v0
VAULT_MIRROR_REPO_URL=/Users/quirinschlegel/git/hive-mind/.local/vault-mirror.git
VAULT_MIRROR_WORKDIR=.local/vault-mirror
WORKER_POLL_INTERVAL_MS=4000
WORKER_MAX_ATTEMPTS=6
CALLBACK_SECRET_ENCRYPTION_KEY=
CALLBACK_REQUEST_TIMEOUT_MS=2500
GIT_AUTHOR_NAME=Hive Mind Worker
GIT_AUTHOR_EMAIL=worker@hive-mind.club
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Optional: send traces and logs to Maple (https://ingest.maple.dev). Set MAPLE_API_KEY to enable.
# For the Next.js web app, put these in apps/web/.env.local (Next loads env from the app dir).
# MAPLE_OTEL_INGEST_URL=https://ingest.maple.dev
# MAPLE_API_KEY=
