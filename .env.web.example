# Copy from .env.shared.example and extend for web runtime
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
APP_JWT_SECRET=replace-with-32-char-min-secret-1234
APP_DOMAIN=hive-mind.club
BETTER_AUTH_SECRET=replace-with-better-auth-secret
BETTER_AUTH_URL=http://127.0.0.1:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://127.0.0.1:3000
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@hive-mind.club
TREASURY_ADMIN_EMAIL_ALLOWLIST=admin@hive-mind.club
TREASURY_ADMIN_WALLET_ALLOWLIST=0x1111111111111111111111111111111111111111
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
TREASURY_VOTE_QUORUM_XP=1000
TREASURY_DEFAULT_VOTING_WINDOW_HOURS=168
CHAIN_EVM_ENABLED=true
CHAIN_CARDANO_ENABLED=true
CHAIN_BITCOIN_ENABLED=true
BITCOIN_NETWORK=mainnet
