# Copy from .env.shared.example and extend for worker runtime
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
APP_JWT_SECRET=replace-with-32-char-min-secret-1234
TREASURY_VOTE_QUORUM_XP=1000
TREASURY_DEFAULT_VOTING_WINDOW_HOURS=168
CHAIN_EVM_ENABLED=true
CHAIN_CARDANO_ENABLED=true
CHAIN_BITCOIN_ENABLED=true
BITCOIN_NETWORK=mainnet
IPFS_API_URL=http://127.0.0.1:5001/api/v0
VAULT_MIRROR_REPO_URL=/Users/quirinschlegel/git/hive-mind/.local/vault-mirror.git
VAULT_MIRROR_WORKDIR=.local/vault-mirror
WORKER_POLL_INTERVAL_MS=4000
WORKER_MAX_ATTEMPTS=6
CALLBACK_SECRET_ENCRYPTION_KEY=
CALLBACK_REQUEST_TIMEOUT_MS=2500
GIT_AUTHOR_NAME=Hive Mind Worker
GIT_AUTHOR_EMAIL=worker@hive-mind.club
